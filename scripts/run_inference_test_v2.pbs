#!/bin/bash
#PBS -N openvla_infer_test
#PBS -l select=1:ncpus=8:ngpus=1:mem=64GB
#PBS -l walltime=01:00:00
#PBS -j oe
# 不在这里写 ${PBS_JOBID}，PBS 指令不会展开变量
#PBS -o /home/users/ntu/zuyu001/OPENVLA/logs/pbs_openvla_latest.log

set -eo pipefail

PROJECT_DIR="/home/users/ntu/zuyu001/OPENVLA"
LOG_DIR="${PROJECT_DIR}/logs"

mkdir -p "${LOG_DIR}"

echo "========== JOB START =========="
echo "DATE      : $(date)"
echo "JOB_ID    : ${PBS_JOBID}"
echo "HOST      : $(hostname)"
echo "WORKDIR   : ${PBS_O_WORKDIR}"
echo "==============================="

# 不 source ~/.bashrc，避免 bashrc 里的变量问题
source "$HOME/miniconda3/etc/profile.d/conda.sh"
conda activate vla_env

echo "[ENV] python: $(which python)"
python --version

echo "[ENV] GPU info:"
nvidia-smi

cd "${PROJECT_DIR}"

echo "[ENV] package versions:"
python - <<'PY'
import torch, transformers, tokenizers
print("torch:", torch.__version__)
print("transformers:", transformers.__version__)
print("tokenizers:", tokenizers.__version__)
print("cuda_available:", torch.cuda.is_available())
PY

echo "========== RUN TEST =========="
RUN_LOG="${LOG_DIR}/infer_${PBS_JOBID}.pbs.log"
python inference/run_inference.py --test 2>&1 | tee "${RUN_LOG}"

echo "========== JOB END =========="
echo "DATE      : $(date)"

# 归档一份带 job id 的日志，便于追踪
cp -f "${LOG_DIR}/pbs_openvla_latest.log" "${LOG_DIR}/pbs_openvla_${PBS_JOBID}.log"
echo "[LOG] inference log: ${RUN_LOG}"